# Personal tmux overrides layered on top of Omarchy's base config.

# Change prefix from Omarchy defaults to C-t
unbind C-b
set-option -g prefix C-t
bind-key C-t send-prefix

# 24 hour clock
setw -g clock-mode-style 24

# History limit
set-option -g history-limit 10000

# Enable true color support
set-option -ga terminal-overrides ",$TERM:Tc"
set-option -g default-terminal "screen-256color"

# Disable mouse support
set -g mouse off

# No delay for escape key press
set -sg escape-time 0

# Increase repeat timeout
set -sg repeat-time 600

# Renumber windows automatically
set-option -g renumber-windows on

# Split panes using | and -
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# Resize panes with Ctrl-arrow
bind -r C-h resize-pane -L 5
bind -r C-j resize-pane -D 5
bind -r C-k resize-pane -U 5
bind -r C-l resize-pane -R 5

# Synchronize panes
bind e setw synchronize-panes on \; display "Synchronize: ON"
bind E setw synchronize-panes off \; display "Synchronize: OFF"

# Vi copy mode bindings
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "{{- if eq .chezmoi.os "darwin" }}pbcopy{{- else }}xclip -in -selection clipboard{{- end }}"
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle

# Quick window selection
bind -r C-p previous-window
bind -r C-n next-window

# Center window list and keep activity alerts
set -g status-justify centre
setw -g monitor-activity on
set -g visual-activity off

# Plugin Manager (TPM)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-copycat'
set -g @plugin 'tmux-plugins/tmux-pain-control'
set -g @plugin 'janoamaral/tokyo-night-tmux'

set -g @tokyo-night-tmux_window_id_style none
set -g @tokyo-night-tmux_date_format YMD
set -g @tokyo-night-tmux_time_format 24H
set -g @tokyo-night-tmux_show_battery_widget 1
set -g @tokyo-night-tmux_battery_low_threshold 21

# Keep TPM init at the end of the local overlay.
run '~/.tmux/plugins/tpm/tpm'
