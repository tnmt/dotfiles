# Prompt
if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"

    # Transient prompt: Enterを押すと以前のプロンプトをシンプルに置換
    zle-line-init() {
        emulate -L zsh
        [[ $CONTEXT == start ]] || return 0

        while true; do
            zle .recursive-edit
            local -i ret=$?
            [[ $ret == 0 && $KEYS == $'\4' ]] || break
            [[ -o ignore_eof ]] || exit 0
        done

        local saved_prompt=$PROMPT
        local saved_rprompt=$RPROMPT
        PROMPT=$'\n❯ '
        RPROMPT=''
        zle .reset-prompt
        PROMPT=$saved_prompt
        RPROMPT=$saved_rprompt

        if (( ret )); then
            zle .send-break
        else
            zle .accept-line
        fi
        return ret
    }
    zle -N zle-line-init
fi

[ -f ~/.iterm2_shell_integration.zsh ] && source ~/.iterm2_shell_integration.zsh

