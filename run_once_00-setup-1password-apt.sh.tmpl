{{ if and .development (eq .chezmoi.os "linux") -}}
#!/bin/bash

set -euo pipefail

if ! command -v apt >/dev/null 2>&1; then
    exit 0
fi

if [ ! -f /etc/os-release ]; then
    exit 0
fi

. /etc/os-release

if [ "${ID:-}" != "ubuntu" ]; then
    exit 0
fi

ARCH="$(dpkg --print-architecture)"
KEYRING_PATH="/usr/share/keyrings/1password-archive-keyring.gpg"
LIST_PATH="/etc/apt/sources.list.d/1password.list"
LIST_CONTENT="deb [arch=${ARCH} signed-by=${KEYRING_PATH}] https://downloads.1password.com/linux/debian/${ARCH} stable main"
DEBSIG_POLICY_DIR="/etc/debsig/policies/AC2D62742012EA22"
DEBSIG_POLICY_PATH="${DEBSIG_POLICY_DIR}/1password.pol"
DEBSIG_KEYRING_DIR="/usr/share/debsig/keyrings/AC2D62742012EA22"
DEBSIG_KEYRING_PATH="${DEBSIG_KEYRING_DIR}/debsig.gpg"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

curl -fsSL https://downloads.1password.com/linux/keys/1password.asc -o "${TMP_DIR}/1password.asc"
gpg --dearmor < "${TMP_DIR}/1password.asc" > "${TMP_DIR}/1password-archive-keyring.gpg"
sudo install -Dm644 "${TMP_DIR}/1password-archive-keyring.gpg" "${KEYRING_PATH}"

printf '%s\n' "${LIST_CONTENT}" | sudo tee "${LIST_PATH}" >/dev/null

sudo install -d -m755 "${DEBSIG_POLICY_DIR}"
curl -fsSL https://downloads.1password.com/linux/debian/debsig/1password.pol | sudo tee "${DEBSIG_POLICY_PATH}" >/dev/null

sudo install -d -m755 "${DEBSIG_KEYRING_DIR}"
gpg --dearmor < "${TMP_DIR}/1password.asc" > "${TMP_DIR}/debsig.gpg"
sudo install -Dm644 "${TMP_DIR}/debsig.gpg" "${DEBSIG_KEYRING_PATH}"

sudo apt update
{{ end -}}
