#!/bin/bash

# Bootstrap package managers and sync declared apt/pacman packages
set -e

OS="$(uname -s)"

{{- $pkgMapping := include "dot_config/packages/package-mapping.toml" | fromToml }}

log() {
    printf '==> %s\n' "$1"
}

warn() {
    printf 'WARNING: %s\n' "$1" >&2
}

bootstrap_homebrew() {
{{ if and .development (or (eq .chezmoi.os "darwin") (and (eq .chezmoi.os "linux") (not (has .chezmoi.osRelease.id (list "arch" "gentoo"))))) -}}
    if command -v brew &> /dev/null; then
        return
    fi

    log "Installing Homebrew"
    if [ "$OS" = "Linux" ]; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> ~/.zprofile
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [ "$OS" = "Darwin" ]; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
{{- else }}
    return
{{- end }}
}

bootstrap_paru() {
{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
    if command -v paru &> /dev/null; then
        return
    fi

    log "Installing paru"
    sudo pacman -S --needed --noconfirm base-devel git
    PARU_TMPDIR="$(mktemp -d)"
    git clone https://aur.archlinux.org/paru.git "$PARU_TMPDIR/paru"
    (cd "$PARU_TMPDIR/paru" && makepkg -si --noconfirm)
    rm -rf "$PARU_TMPDIR"
{{- else }}
    return
{{- end }}
}

sync_arch_packages() {
{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
    PKG_CMD="paru -S --needed --noconfirm"

    log "Installing declared Arch packages"
    $PKG_CMD \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "pacman") (eq $pkg.mode "base") }}
        {{ $pkg.pacman }} \
{{- end }}
{{- end }}
        # end of base packages

{{ if .development }}
    $PKG_CMD \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "pacman") (eq $pkg.mode "development") }}
        {{ $pkg.pacman }} \
{{- end }}
{{- end }}
        # end of development packages
{{ end -}}
{{- else }}
    return
{{- end }}
}

sync_portage_packages() {
{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "gentoo") -}}
    # Accept keywords for testing packages
    KEYWORDS_FILE="/etc/portage/package.accept_keywords/chezmoi"
    sudo tee "$KEYWORDS_FILE" > /dev/null <<'KWEOF'
# Managed by chezmoi — do not edit manually
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "portage") (hasKey $pkg "portage_keywords") }}
{{ $pkg.portage }} {{ $pkg.portage_keywords }}
{{- end }}
{{- end }}
KWEOF

    log "Installing declared Portage packages"
    sudo emerge --noreplace --quiet \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "portage") (eq $pkg.mode "base") }}
        {{ $pkg.portage }} \
{{- end }}
{{- end }}
        # end of base packages

{{ if .development }}
    sudo emerge --noreplace --quiet \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "portage") (eq $pkg.mode "development") }}
        {{ $pkg.portage }} \
{{- end }}
{{- end }}
        # end of development packages
{{ end -}}

{{ if .desktop }}
    sudo emerge --noreplace --quiet \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "portage") (eq $pkg.mode "desktop") }}
        {{ $pkg.portage }} \
{{- end }}
{{- end }}
        # end of desktop packages
{{ end -}}
{{- else }}
    return
{{- end }}
}

sync_apt_packages() {
{{ if and (eq .chezmoi.os "linux") (not (has .chezmoi.osRelease.id (list "arch" "gentoo"))) -}}
    if ! command -v apt &> /dev/null; then
        return
    fi

    log "Installing declared apt packages"
    sudo apt update

    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "base") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of base packages

{{ if .development }}
    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "development") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of development packages
{{ end -}}

{{ if .desktop }}
    # Desktop fonts
    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "desktop") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of desktop packages
{{ end -}}
{{- else }}
    return
{{- end }}
}

install_desktop_apps() {
{{ if .desktop -}}
    log "Installing desktop applications"
{{ if eq .chezmoi.os "linux" -}}
    if command -v flatpak &> /dev/null; then
        flatpak install -y flathub \
            com.visualstudio.code \
            com.slack.Slack
    fi
{{ end -}}
{{ if eq .chezmoi.os "darwin" -}}
    brew install --cask alacritty
{{ end -}}
{{- else }}
    return
{{- end }}
}

bootstrap_mise() {
{{ if .development -}}
    if command -v mise &> /dev/null; then
        return
    fi

    log "Installing mise"
    curl https://mise.run | sh
{{- else }}
    return
{{- end }}
}

sync_mise_tools() {
{{ if .development -}}
    if ! command -v mise &> /dev/null; then
        return
    fi

    log "Installing development runtimes with mise"
    mkdir -p "$HOME/.config/mise"
    if [ -f "$HOME/.config/mise/config.toml" ]; then
        :
    else
        cat >"$HOME/.config/mise/config.toml" <<'EOF'
{{ includeTemplate "dot_config/mise/config.toml.tmpl" . -}}
EOF
    fi
    if ! mise install bun node python go rust usage \
        npm:@openai/codex npm:ccusage; then
        warn "mise runtime install failed. Continuing chezmoi apply."
        warn "Retry manually with: mise install bun node python go rust usage npm:@openai/codex npm:ccusage"
        return 0
    fi
    mise reshim
    printf '%s\n' "Skipping Ruby and Gemini CLI during bootstrap. Install later with: mise install ruby@3.4 npm:@google/gemini-cli"
{{- else }}
    return
{{- end }}
}

bootstrap_homebrew
bootstrap_paru
sync_arch_packages
sync_portage_packages
sync_apt_packages
install_desktop_apps
bootstrap_mise
sync_mise_tools

log "Package installation completed"
