#!/bin/bash

# Install packages based on OS and available package managers
set -e

OS="$(uname -s)"

{{- $pkgMapping := include "dot_config/packages/package-mapping.toml" | fromToml }}

{{ if .development -}}
{{- if or (eq .chezmoi.os "darwin") (and (eq .chezmoi.os "linux") (ne .chezmoi.osRelease.id "arch")) }}
# Install Homebrew if not installed
if ! command -v brew &> /dev/null; then
    echo "Installing Homebrew..."
    if [ "$OS" = "Linux" ]; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> ~/.zprofile
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [ "$OS" = "Darwin" ]; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
fi

# Install packages with Homebrew
if command -v brew &> /dev/null; then
    echo "Installing packages with Homebrew..."
    brew bundle --file=~/.config/packages/brewfile
fi
{{- end }}
{{ end -}}


# Linux-specific packages (using native package manager)
{{ if eq .chezmoi.os "linux" -}}
{{- if eq .chezmoi.osRelease.id "arch" }}
# Arch Linux: use paru (or pacman)
if command -v paru &> /dev/null; then
    PKG_CMD="paru -S --needed --noconfirm"
else
    PKG_CMD="sudo pacman -S --needed --noconfirm"
fi

echo "Installing Arch Linux packages..."

# Base packages
$PKG_CMD \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "pacman") (eq $pkg.mode "base") }}
    {{ $pkg.pacman }} \
{{- end }}
{{- end }}
    # end of base packages

{{- else }}
if command -v apt &> /dev/null; then
    echo "Installing Linux packages with apt..."
    sudo apt update

    # Base packages
    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "base") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of base packages

{{ if .development }}
    # Build tools and development libraries (for mise/ruby-build etc.)
    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "development") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of development packages
{{ end -}}

{{ if .desktop }}
    # Desktop fonts
    sudo apt install -y \
{{- range $name, $pkg := $pkgMapping }}
{{- if and (hasKey $pkg "apt") (eq $pkg.mode "desktop") }}
        {{ $pkg.apt }} \
{{- end }}
{{- end }}
        # end of desktop packages
{{ end -}}
fi
{{- end }}
{{ end -}}

# Desktop-specific packages
{{ if .desktop -}}
echo "Installing desktop applications..."

{{ if eq .chezmoi.os "linux" -}}
# Linux desktop apps
if command -v flatpak &> /dev/null; then
    flatpak install -y flathub \
        com.visualstudio.code \
        com.slack.Slack
fi
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
# macOS desktop apps
brew install --cask \
    alacritty
{{ end -}}
{{ end -}}

{{ if .development -}}
# Install mise (development tool version manager)
if ! command -v mise &> /dev/null; then
    echo "Installing mise..."
    curl https://mise.run | sh
    if [ -f "$HOME/.config/zsh/.zshrc" ] && ! grep -q 'mise activate zsh' "$HOME/.config/zsh/.zshrc"; then
        echo 'eval "$(~/.local/bin/mise activate zsh)"' >> "$HOME/.config/zsh/.zshrc"
    fi
fi

# Setup mise tools without overriding existing config
if command -v mise &> /dev/null; then
    mkdir -p "$HOME/.config/mise"
    if [ -f "$HOME/.config/mise/config.toml" ]; then
        # Skip Ruby during bootstrap because source builds are slow.
        mise install bun node python go rust usage \
            npm:@openai/codex npm:ccusage
    else
        cat >"$HOME/.config/mise/config.toml" <<'EOF'
{{ includeTemplate "dot_config/mise/config.toml.tmpl" . -}}
EOF
        # Skip Ruby during bootstrap because source builds are slow.
        mise install bun node python go rust usage \
            npm:@openai/codex npm:ccusage
    fi
    echo "Skipping Ruby and Gemini CLI during bootstrap. Install later with: mise install ruby@3.4 npm:@google/gemini-cli"
fi
{{ end -}}

echo "Package installation completed!"
