{{ if .desktop -}}
#!/bin/bash

# External/manual font installer for Linux fallback.
# System packages and macOS font casks should come from package-mapping.toml.
# Use this script only to install upstream font assets when package-manager delivery
# is not the source of truth.
set -e

log() {
    printf '==> %s\n' "$1"
}

font_dir() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        printf '%s\n' "$HOME/Library/Fonts"
    else
        printf '%s\n' "$HOME/.local/share/fonts"
    fi
}

install_nerd_fonts() {
    local target_dir
    target_dir="$(font_dir)"

    mkdir -p "$target_dir"

    if ! ls "$target_dir"/MesloLGS* &>/dev/null; then
        log "Installing MesloLGS Nerd Font from upstream assets"
        local tmp_dir
        local style
        local style_file
        tmp_dir="$(mktemp -d)"
        cd "$tmp_dir"

        for style in Regular Bold Italic "Bold Italic"; do
            style_file=$(echo "$style" | sed 's/ /%20/g')
            curl -fLo "MesloLGS NF ${style}.ttf" \
                "https://github.com/romkatv/powerlevel10k-media/raw/master/MesloLGS%20NF%20${style_file}.ttf"
        done

        mv *.ttf "$target_dir/"
        cd - >/dev/null
        rm -rf "$tmp_dir"

        log "MesloLGS Nerd Font installed successfully"
    else
        log "MesloLGS Nerd Font already installed"
    fi

    if ! ls "$target_dir"/FiraCode* &>/dev/null; then
        if ! command -v unzip &>/dev/null; then
            printf '%s\n' "Warning: unzip not found, skipping FiraCode Nerd Font manual install." >&2
        else
            log "Installing FiraCode Nerd Font from upstream assets"
            local tmp_dir
            tmp_dir="$(mktemp -d)"
            cd "$tmp_dir"

            curl -fLo FiraCode.zip \
                "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip"

            unzip -q FiraCode.zip
            mv *.ttf "$target_dir/" 2>/dev/null || true
            mv *.otf "$target_dir/" 2>/dev/null || true

            cd - >/dev/null
            rm -rf "$tmp_dir"

            log "FiraCode Nerd Font installed successfully"
        fi
    else
        log "FiraCode Nerd Font already installed"
    fi

    if [[ "$OSTYPE" != "darwin"* ]] && command -v fc-cache &>/dev/null; then
        log "Updating font cache"
        fc-cache -f "$target_dir"
    fi
}

if [[ "$OSTYPE" == "darwin"* ]]; then
    log "Skipping manual font install on macOS; use Homebrew casks from package-mapping.toml"
    exit 0
fi

if command -v pacman &>/dev/null; then
    log "Skipping manual font install on Arch; use pacman packages from package-mapping.toml"
    exit 0
fi

install_nerd_fonts

log "Font installation completed"
printf '%s\n' ""
printf '%s\n' "Recommended fonts for terminals:"
printf '%s\n' "  - MesloLGS Nerd Font"
printf '%s\n' "  - FiraCode Nerd Font (good ligatures support)"
printf '%s\n' ""
printf '%s\n' "You may need to restart your terminal and select the font in preferences."
{{ end -}}
