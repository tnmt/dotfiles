{{ if .development -}}
#!/bin/bash

# External installer for Claude CLI and related tooling.
# Keep package-manager sync in run_once_01; use this only for tools that intentionally
# follow the upstream installer instead of package-mapping.toml.
set -e

log() {
    printf '==> %s\n' "$1"
}

install_claude() {
    if command -v claude &> /dev/null; then
        log "Claude CLI is already installed: $(claude --version)"
        return
    fi

    log "Installing Claude CLI with the official installer"
    curl -fsSL https://claude.ai/install.sh | bash

    if ! command -v claude &> /dev/null; then
        printf '%s\n' "Error: Claude CLI installation failed or not found in PATH" >&2
        exit 1
    fi

    log "Claude CLI installation completed: $(claude --version)"
}

install_claude_chill() {
    if command -v claude-chill &> /dev/null; then
        log "claude-chill is already installed"
        return
    fi

    if command -v cargo &> /dev/null; then
        log "Installing claude-chill"
        cargo install --git https://github.com/davidbeesley/claude-chill
        log "claude-chill installation completed"
    else
        printf '%s\n' "Warning: cargo not found, skipping claude-chill installation."
    fi
}

install_claude
install_claude_chill
{{ end -}}
